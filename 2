#include <stdio.h>
#include <locale.h>

// Функция удаляет из строки многострочные комментарии в стиле C (/* ... */).
// Входной параметр: c[] - строка, которую мы обрабатываем.
void F13(char c[]) {
    int i;  // i - индекс для чтения исходной строки
    int j;  // j - индекс для записи символов в новую строку
    int cm; // cm - счетчик "глубины" комментариев (0 - мы не в комментарии)

    // Проходим по всей строке до символа конца строки '\0'
    for (i = 0, j = 0, cm = 0; c[i] != '\0'; i++) {

        // Если видим начало комментария '/*'
        if (c[i] == '/' && c[i + 1] == '*') {
            cm++; // Увеличиваем уровень погружения в комментарий
            i++;  // Пропускаем следующий символ '*', чтобы не обработать его дважды
            continue;
        }

        // Если видим конец комментария '*/'
        if (c[i] == '*' && c[i + 1] == '/') {
            cm--; // Уменьшаем уровень погружения
            i++;  // Пропускаем следующий символ '/'
            continue;
        }

        // Если мы не находимся внутри комментария (cm == 0)
        if (cm == 0) {
            c[j++] = c[i]; // Записываем текущий символ обратно в строку
        }
    }

    c[j] = '\0'; // Ставим символ конца строки, отрезая старый "мусор"
}

int main() {
    setlocale(LC_ALL, "Russian");
    char text[] = "сообщение /* комментарий */ и /* еще */ сообщение";
    F13(text);
    printf("Result: %s\n", text); // Выведет: Code  and  text
    return 0;
}
