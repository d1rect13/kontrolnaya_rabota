#include <stdio.h>
#include <math.h>
#include <locale.h>

/*
     Для заданного варианта написать функцию вычисления суммы ряда. Вычислить значения суммы ряда и контрольной функции, к которой он сходится.
     Для вариантов 13-17 необходимо реализовать рекуррентное вычисление значений $sin$ и $cos$ для кратных значений аргумента $nx$. 
     При оценке сходимости ряда учесть, что он не является монотонно убывающим, и для оценки граничного значения слагаемого заменить в формуле $sin$ и $cos$ на 1.

*/



// Функция вычисляет сумму ряда с заданной точностью eps
double sum_series(double x, double eps) {
    double sum = 0.0; // Сумма ряда

    // Начальные значения для рекуррентного расчета (при n=1 угол равен x)
    double sin_val = sin(x);
    double cos_val = cos(x);

    // Шаг изменения угла равен 2x (т.к. углы идут x, 3x, 5x...)
    double sin_step = sin(2 * x);
    double cos_step = cos(2 * x);

    int k = 1; // k заменяет выражение (2n-1)

    // По заданию: для оценки сходимости меняем sin на 1.
    // Значит условие выхода: 1 / k^3 > eps
    while ((1.0 / (k * k * k)) > eps) {

        // 1. Вычисляем текущее слагаемое
        double term = sin_val / (k * k * k);
        sum += term; // Добавляем в общую сумму

        // 2. Рекуррентно вычисляем sin и cos для следующего шага (по формулам суммы углов)
        // sin(a + b) = sin(a)cos(b) + cos(a)sin(b)
        double next_sin = sin_val * cos_step + cos_val * sin_step;
        // cos(a + b) = cos(a)cos(b) - sin(a)sin(b)
        double next_cos = cos_val * cos_step - sin_val * sin_step;

        sin_val = next_sin; // Обновляем текущий синус
        cos_val = next_cos; // Обновляем текущий косинус

        k += 2; // Увеличиваем нечетный знаменатель на 2 для следующего шага
    }

    return sum;
}

int main() {
    setlocale(LC_ALL, "Russian");
    double eps = 1e-4; // Точность сходимости 0.0001
    double pi = 3.1415926535;

    printf("Точность сходимости: %.e\n", eps);
    printf("x\t  Сумма ряда\t Функция\n");

    // Стандартный диапазон x = 0.1 ... 1.0 с шагом 0.1
    for (double x = 0.1; x <= 1.0; x += 0.1) {
        double func_val = x * (pi - x) * (pi / 8.0); // Значение эталонной функции
        double sum_val = sum_series(x, eps);         // Значение, вычисленное рядом

        // Выводим с точностью до 4 знаков после запятой
        printf("%.1f\t  %.4f\t %.4f\n", x, sum_val, func_val);
    }

    return 0;
}
