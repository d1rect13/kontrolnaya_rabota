#include <stdio.h>

// Функция проверяет, является ли число 'a' простым.
// Входной параметр: a - число для проверки.
// Выходной параметр: 1 (если простое), 0 (если не простое).
int F5(int a){
    int s=0; // s - счетчик количества делителей числа
    
    // Перебираем все возможные делители от 2 до a-1
    for (int n=2; n<a; n++) { 
        if (a%n==0) { 
            s++; // Если число 'a' делится на 'n' без остатка, увеличиваем счетчик
        } 
    }
    
    // Если мы не нашли ни одного делителя (счетчик остался равен 0)
    if (s==0) return 1; // Значит число простое
    
    return 0; // Иначе число имеет делители (не простое)
}

int main(){
    printf("F5(7) = %d\n", F5(7));   // Выведет 1 (число простое)
    printf("F5(10) = %d\n", F5(10)); // Выведет 0 (число не простое, делится на 2 и 5)
    return 0;
}
